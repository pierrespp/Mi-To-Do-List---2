# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc
*.tsbuildinfo
.expo
.expo-shared

# dependencies
node_modules

# IDE - VSCode
.vscode/

# Assets & Agent
attached_assets/
.agent/
.agent_backups/
.gemini/

# Generated / heavy media
artifacts/**/*.mp4
artifacts/**/*.mov
artifacts/**/*.webm
artifacts/**/recordings/
artifacts/**/screenshots/
artifacts/**/tmp/
artifacts/**/.cache/

# Raw or backup image exports
artifacts/**/*-backup.png
artifacts/**/*-backup.webp
artifacts/**/*-raw.png
artifacts/**/*-raw.webp
artifacts/**/*.bak
artifacts/**/*.tmp

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# Replit
.cache/
.local/

# Security
.env
.env.local
.env.*.local
.replit-artifact/
*.log

# Local databases / dumps
*.db
*.sqlite
*.sqlite3
*.dump
*dump*.sql
*backup*.sql
*export*.sql

# Source maps from builds
dist/**/*.map
build/**/*.map
artifacts/**/dist/**/*.map
artifacts/**/build/**/*.map
